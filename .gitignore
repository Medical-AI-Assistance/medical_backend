*.pid
*.sock

# VS Code settings
# .vscode/

# OS files
.DS_Store
Thumbs.db

# Environment variables file
.env


# Pytest cache
.pytest_cache/

# Migrations (optional: include if you want to keep migrations versioned)
**/migrations/*.pyc
**/migrations/__pycache__/

# Coverage reports
htmlcov/
.coverage

# Node / frontend (if you have React/Vue)
node_modules/
build/
dist/
npm-debug.log
yarn-error.log
